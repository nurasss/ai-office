# ─── LLM API Keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
GOOGLE_API_KEY=xxxxxxxxxxxxxxxx
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_HEAVY_MODEL=gpt-5.5

# ─── Vector DB ────────────────────────────────────────────────────────
# Option A: pgvector (Postgres)
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ai_office

# Option B: Pinecone
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_INDEX=ai-office
PINECONE_ENV=us-east-1

# ─── External Tools ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=email@example.com
JIRA_API_TOKEN=xxxxxxxxxxxx

# ─── App Config ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
